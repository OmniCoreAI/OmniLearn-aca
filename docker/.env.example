# Copy to docker/.env and adjust values before running:
#   cp docker/.env.example docker/.env
#   docker compose up --build -d

HTTP_PORT=8080
COLLAB_PORT=4040

# Database — pick ONE:
# A) Managed Postgres (DigitalOcean, etc.):
OMNILEARN_SQL_CONNECTION_STRING=postgresql://USER:PASSWORD@HOST:25060/DATABASE?ssl=require
# B) Local compose Postgres (also run: docker compose --profile local-db up -d):
# OMNILEARN_SQL_CONNECTION_STRING=postgresql://omnilearn:omnilearn@db:5432/omnilearn

POSTGRES_USER=omnilearn
POSTGRES_PASSWORD=change-me
POSTGRES_DB=omnilearn

OMNILEARN_DOMAIN=localhost:8080
OMNILEARN_AUTH_JWT_SECRET_KEY=generate-with-python-secrets-token_urlsafe-32
NEXTAUTH_SECRET=generate-with-python-secrets-token_urlsafe-32
COLLAB_INTERNAL_KEY=generate-with-python-secrets-token_urlsafe-32

OMNILEARN_INITIAL_ADMIN_EMAIL=admin@omnicoreai.com
OMNILEARN_INITIAL_ADMIN_PASSWORD=change-me
